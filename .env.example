EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Cle API Google Maps Android (obligatoire pour la map sur Android)
# Obtenir une cle : https://console.cloud.google.com/google/maps-apis
# Active "Maps SDK for Android" et restreins la cle au package com.Studentfood.app + empreinte SHA-1
GOOGLE_MAPS_API_KEY_ANDROID=your-google-maps-android-key

# Crash reporting Sentry (optionnel) — voir docs/SENTRY_SETUP.md
EXPO_PUBLIC_SENTRY_DSN=
